{
  "manifest_version": 3,
  "name": "JSON Inspector",
  "version": "0.0.1",
  "description": "Inspect raw JSON documents with a structured tree and raw view.",
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.iife.js"],
      "css": ["content.iife.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "JSON Inspector"
  }
}
